# Backend Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên GitHub

PORT=5000
NODE_ENV=development

# JWT Secret - thay đổi thành chuỗi ngẫu nhiên dài trong production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS - Các domain được phép truy cập (cách nhau bởi dấu phẩy)
# Ví dụ: http://localhost:3000,https://my-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000

# SQLite Database Path (Mặc định trong Docker là /app/data/database.sqlite)
DATABASE_PATH=./database.sqlite
